{
    "name": "sunnysideup/array2ul",
    "description": "Convert an associative Array to a UL for display in the CMS and elsewhere",
    "type": "silverstripe-vendormodule",
    "keywords": [
        "array",
        "ul",
        "debug",
        "nice",
        "unordered list",
        "cms"
    ],
    "license": "BSD-3-Clause",
    "require": {
        "silverstripe/framework": "^6.0",
        "silverstripe/admin": "^3.0"
    },
    "require-dev": {
        "sunnysideup/sswebpack_engine_only": "^5.0-dev",
        "silverleague/ideannotator": "*",
        "phpunit/phpunit": "^9.6",
        "squizlabs/php_codesniffer": "^3.7",
        "silverstripe/standards": "^1",
        "phpstan/extension-installer": "^1.3"
    },
    "autoload": {
        "psr-4": {
            "Sunnysideup\\ArrayToUl\\": "src/"
        }
    },
    "extra": {
        "expose": [
            "client/dist"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "authors": [
        {
            "name": "Nicolaas Thiemen Francken",
            "email": "modules@sunnysideup.co.nz",
            "role": "lead developer"
        }
    ]
}
